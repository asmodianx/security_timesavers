[
  {
    "id": "db_encoded_powershell",
    "title": "Encoded PowerShell Command",
    "severity": "high",
    "logsource": "security",
    "tags": ["attack.execution", "attack.t1059.001"],
    "logic": "all",
    "conditions": [[
      { "field": "event_id", "op": "equals", "value": 4688 },
      { "field": "command_line", "op": "regex", "value": "-enc\\s+[A-Za-z0-9+/=]{20,}" }
    ]]
  },
  {
    "id": "db_long_command_line",
    "title": "Suspiciously Long Command Line",
    "severity": "medium",
    "logsource": "security",
    "tags": ["attack.execution"],
    "logic": "all",
    "conditions": [[
      { "field": "event_id", "op": "equals", "value": 4688 },
      { "field": "command_line", "op": "regex", "value": ".{300,}" }
    ]]
  },
  {
